# Ref4EP-Portal — Beispiel-Konfiguration
# Kopiere nach backend/.env und passe Werte an. Datei ist gitignored.

# --- Datenbank ---
# Lokaler Entwicklungsdefault: SQLite-Datei unter ./data/ref4ep.db
REF4EP_DATABASE_URL=sqlite:///../data/ref4ep.db
# Produktiv-Beispiel:
# REF4EP_DATABASE_URL=postgresql+psycopg://ref4ep:ref4ep@localhost:5432/ref4ep

# --- Auth & Sessions (Sprint 1+) ---
# Pflicht. Mindestens 32 Zeichen Entropie. Settings() schlägt fehl,
# wenn die Variable leer oder zu kurz ist.
# Beispiel: openssl rand -hex 32
REF4EP_SESSION_SECRET=

# Cookie-Sicherheit. Default ist true — Cookies werden nur über
# HTTPS gesendet. Für lokale Entwicklung über http://localhost
# muss dieser Wert explizit auf false gesetzt werden, sonst
# speichert der Browser das Session-Cookie nicht.
REF4EP_COOKIE_SECURE=false

# --- Storage (Sprint 2+) ---
REF4EP_STORAGE_DIR=../data/storage
REF4EP_MAX_UPLOAD_MB=100

# --- Öffentliche Basis-URL ---
REF4EP_PUBLIC_BASE_URL=http://localhost:8000

# --- Logging ---
# text (Dev) | json (Prod)
REF4EP_LOG_FORMAT=text
